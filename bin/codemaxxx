#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────
#  codemax — One-shot CLI to install Ollama, pull eburonmax/codemax-v3,
#              install OpenCode, and launch OpenCode through Ollama.
#
#  Usage:
#    codemax                   # launch TUI agent
#    codemax bootstrap         # full bootstrap + launch
#    codemax launch            # quick launch (skip install steps)
#    codemax install           # install everything, don't launch
#    codemax pull              # just pull/update the model
#    codemax help              # show usage
#
#  Environment:
#    EBURON_OLLAMA_MODEL  override model  (default: eburonmax/codemax-v3)
# ─────────────────────────────────────────────────────────────────────
set -euo pipefail

MODEL="${EBURON_OLLAMA_MODEL:-eburonmax/codemax-v3}"
CLI_NAME="${CODEMAX_CLI_NAME:-$(basename "$0")}"

resolve_repo_dir() {
  local src="${BASH_SOURCE[0]}"
  while [[ -h "$src" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="${dir}/${src}"
  done
  cd -P "$(dirname "$src")/.." && pwd
}

# ── Helpers ────────────────────────────────────────────────────────
info()  { printf '  \033[1;34mℹ\033[0m  %s\n' "$*"; }
ok()    { printf '  \033[1;32m✔\033[0m  %s\n' "$*"; }
warn()  { printf '  \033[1;33m⚠\033[0m  %s\n' "$*" >&2; }
err()   { printf '  \033[1;31m✖\033[0m  %s\n' "$*" >&2; }
step()  { printf '\n\033[1;36m── %s ──\033[0m\n' "$*"; }

# ── 1  Install / Update Ollama ─────────────────────────────────────
install_ollama() {
  step "[1/4] Updating / Installing Ollama"

  if command -v brew >/dev/null 2>&1; then
    info "Using Homebrew..."
    brew update --quiet
    if brew list --formula ollama >/dev/null 2>&1; then
      brew upgrade ollama 2>/dev/null || ok "Ollama already at latest"
    else
      brew install ollama
    fi
  fi

  # Linux fallback: use official installer when Ollama is not present.
  if ! command -v ollama >/dev/null 2>&1 && [[ "$(uname -s)" == "Linux" ]]; then
    if command -v curl >/dev/null 2>&1; then
      info "Linux detected — installing Ollama via official installer..."
      curl -fsSL https://ollama.com/install.sh | sh
    else
      err "curl is required to install Ollama on Linux."
      err "Install curl first, then run '${CLI_NAME} install' again."
      exit 1
    fi
  fi

  # macOS app fallback: create symlink to embedded CLI
  if ! command -v ollama >/dev/null 2>&1; then
    local app_cli="/Applications/Ollama.app/Contents/Resources/ollama"
    if [[ -x "$app_cli" ]]; then
      info "Ollama.app detected — creating /usr/local/bin/ollama symlink (may need sudo)..."
      sudo mkdir -p /usr/local/bin
      sudo ln -sf "$app_cli" /usr/local/bin/ollama
    fi
  fi

  if ! command -v ollama >/dev/null 2>&1; then
    err "ollama not found in PATH."
    err "Install via Homebrew or Ollama.app: https://ollama.com/download"
    exit 1
  fi

  ok "Ollama ready: $(ollama --version 2>/dev/null || echo 'version unknown')"
}

# ── 2  Ensure Ollama server is running ─────────────────────────────
ensure_server() {
  step "[2/4] Ensuring Ollama server is running"

  if ollama ps >/dev/null 2>&1; then
    ok "Server already running"
  else
    info "Starting ollama serve in background..."
    nohup ollama serve >/tmp/ollama-serve.log 2>&1 &
    sleep 2
    if ollama ps >/dev/null 2>&1; then
      ok "Server started (PID $!)"
    else
      warn "Server may not be ready yet — continuing anyway"
    fi
  fi
}

# ── 3  Pull the model ─────────────────────────────────────────────
pull_model() {
  step "[3/4] Pulling model: ${MODEL}"
  ollama pull "${MODEL}"
  ok "Model ${MODEL} is available"
}

# ── 4  Install OpenCode ────────────────────────────────────────────
install_opencode() {
  step "[4/4] Installing OpenCode"

  if command -v opencode >/dev/null 2>&1; then
    ok "opencode already installed: $(opencode --version 2>/dev/null || echo '')"
    return 0
  fi

  info "Downloading via official installer..."
  curl -fsSL https://opencode.ai/install | bash
  hash -r 2>/dev/null || true

  if command -v opencode >/dev/null 2>&1; then
    ok "opencode installed"
  else
    warn "opencode not found in current PATH — open a new terminal or run: source ~/.zshrc"
  fi
}

# ── Launch ─────────────────────────────────────────────────────────
launch() {
  step "Launching OpenCode with model ${MODEL}"

  if ! command -v ollama >/dev/null 2>&1; then
    err "ollama not found — run '${CLI_NAME} install' first"
    exit 1
  fi

  # Ensure server is up before launch
  if ! ollama ps >/dev/null 2>&1; then
    nohup ollama serve >/tmp/ollama-serve.log 2>&1 &
    sleep 2
  fi

  if ollama launch --help >/dev/null 2>&1; then
    exec ollama launch opencode --model "${MODEL}"
  else
    warn "'ollama launch' not available (requires Ollama v0.15+)."
    info "Falling back to running opencode directly..."
    if command -v opencode >/dev/null 2>&1; then
      exec opencode
    else
      err "Neither 'ollama launch' nor 'opencode' binary found."
      exit 1
    fi
  fi
}

# ── Full bootstrap ─────────────────────────────────────────────────
bootstrap() {
  echo ""
  echo "  🚀  ${CLI_NAME} — Eburon CodeMax Bootstrap"
  echo "  ─────────────────────────────────────────"
  echo "  Model: ${MODEL}"
  echo ""

  install_ollama
  ensure_server
  pull_model
  install_opencode
  launch
}

# ── CLI entry point ────────────────────────────────────────────────
usage() {
  printf '\n'
  printf '  %s — Eburon CodeMax CLI\n\n' "${CLI_NAME}"
  printf '  Usage:\n'
  printf '    %s               Launch CodeMaxxx TUI agent (interactive)\n' "${CLI_NAME}"
  printf '    %s bootstrap     Full bootstrap + launch\n' "${CLI_NAME}"
  printf '    %s tui           Launch CodeMaxxx TUI agent (interactive)\n' "${CLI_NAME}"
  printf '    %s install       Install Ollama, pull model, install OpenCode\n' "${CLI_NAME}"
  printf '    %s launch        Quick launch via ollama launch\n' "${CLI_NAME}"
  printf '    %s pull          Pull / update the model only\n' "${CLI_NAME}"
  printf '    %s help          Show this message\n\n' "${CLI_NAME}"
  printf '  Environment:\n'
  printf '    EBURON_OLLAMA_MODEL     Override model (default: eburonmax/codemax-v3)\n\n'
}

case "${1:-}" in
  bootstrap)
    bootstrap
    ;;
  install)
    install_ollama
    ensure_server
    pull_model
    install_opencode
    ok "All done — run '${CLI_NAME} launch' to start."
    ;;
  ""|tui|agent)
    step "Launching CodeMaxxx TUI Agent"
    SCRIPT_DIR="$(resolve_repo_dir)"
    if [[ "${1:-}" != "" ]]; then
      shift || true
    fi
    if [[ -f "${SCRIPT_DIR}/.venv/bin/python" ]]; then
      exec "${SCRIPT_DIR}/.venv/bin/python" -m codemaxxx.main "$@"
    elif [[ -f "${HOME}/.codemaxxx/.venv/bin/python" ]]; then
      exec "${HOME}/.codemaxxx/.venv/bin/python" -m codemaxxx.main "$@"
    else
      err "Python venv not found — run '${CLI_NAME} install' first"
      exit 1
    fi
    ;;
  launch)
    launch
    ;;
  pull)
    ensure_server
    pull_model
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    err "Unknown command: $1"
    usage
    exit 1
    ;;
esac
